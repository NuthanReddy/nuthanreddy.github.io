---
import SectionHeading from "@/components/SectionHeading.astro";
import { education } from "@/lib/data";
---

<section id="education" class="py-20 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading label="Education" heading="My Education" />
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {education.map((edu) => (
        <div class="rounded-xl bg-surface-card p-6 border border-white/5">
          <h3 class="text-base font-bold text-white">{edu.institution}</h3>
          <p class="mt-2 text-sm text-muted">{edu.studyType} — {edu.area}</p>
          <p class="mt-3 text-xs font-semibold text-accent">{edu.startDate} — {edu.endDate}</p>
        </div>
      ))}
    </div>
  </div>
</section>
