---
import TechTag from "@/components/TechTag.astro";

interface Props {
  position: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
  highlights: string[];
  keywords: string[];
  isLast?: boolean;
}

const { position, company, location, startDate, endDate, highlights, keywords, isLast = false } = Astro.props;
---

<div class="relative pl-8 pb-12">
  <!-- Blue dot marker -->
  <div class="absolute left-0 top-1 w-3 h-3 rounded-full bg-accent border-2 border-surface"></div>
  
  <!-- Vertical connecting line (hidden if isLast) -->
  {!isLast && (
    <div class="absolute left-[5px] top-4 bottom-0 w-0.5 bg-white/10"></div>
  )}
  
  <!-- Content -->
  <div>
    <!-- Position and Company -->
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <h3 class="text-lg font-bold text-white">{position}</h3>
      <span class="text-accent font-semibold">{company}</span>
    </div>
    
    <!-- Date range and location -->
    <p class="text-sm text-muted mt-1">{startDate} — {endDate} · {location}</p>
    
    <!-- Highlights -->
    <ul class="mt-4 space-y-2">
      {highlights.map(h => (
        <li class="text-sm text-muted leading-relaxed pl-4 relative before:content-['▹'] before:absolute before:left-0 before:text-accent">
          {h}
        </li>
      ))}
    </ul>
    
    <!-- Tech tags -->
    <div class="mt-4 flex flex-wrap gap-2">
      {keywords.map(k => (
        <TechTag name={k} />
      ))}
    </div>
  </div>
</div>
