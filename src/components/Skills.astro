---
import SectionHeading from "@/components/SectionHeading.astro";
import { skills } from "@/lib/data";
---

<section id="skills" class="py-20 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading label="Skills" heading="Technical Skills" />
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((group) => (
        <div class="rounded-xl bg-surface-card border border-white/5 p-6">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-white mb-4">{group.name}</h3>
          <div class="flex flex-wrap gap-2">
            {group.keywords.map((keyword) => (
              <span class="inline-flex items-center rounded-full bg-surface border border-white/10 px-3 py-1 text-xs font-mono text-muted">
                {keyword}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
