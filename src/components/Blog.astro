---
import SectionHeading from "@/components/SectionHeading.astro";
---

<section id="blog" class="py-20 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading label="Blog" heading="Thoughts & Writing" />
    <p class="mt-4 text-sm text-muted max-w-2xl">Coming soon — articles on data engineering, distributed systems, and agentic AI.</p>

    <div class="mt-12 rounded-xl bg-surface-card border border-white/5 p-8 text-center">
      <p class="text-muted text-sm">✍️ Blog posts coming soon. Stay tuned!</p>
    </div>
  </div>
</section>
