---
import TechTag from "@/components/TechTag.astro";

interface Props {
  name: string;
  company: string;
  keywords: string[];
  description: string[];
  url?: string;
}

const { name, company, keywords, description, url } = Astro.props;
---

<div class="bg-surface-card p-6 hover:bg-surface-hover transition-colors">
  <div class="flex items-start justify-between">
    <div>
      <h3 class="text-lg font-bold text-white">{name}</h3>
      <p class="text-sm font-semibold text-accent mt-1">{company}</p>
    </div>
    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-accent transition-colors"
        aria-label={`View ${name} project`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          />
        </svg>
      </a>
    )}
  </div>

  <ul class="mt-4 space-y-2">
    {description.map((d) => (
      <li class="text-sm text-muted leading-relaxed pl-4 relative before:content-['▹'] before:absolute before:left-0 before:text-accent break-inside-avoid">
        {d}
      </li>
    ))}
  </ul>

  <div class="mt-4 flex flex-wrap gap-2">
    {keywords.map((k) => <TechTag name={k} />)}
  </div>
</div>
